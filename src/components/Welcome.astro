---
import { siteData } from "../data/site";
---

<main class="container mx-auto grid min-h-dvh max-w-2xl place-items-center px-4 py-16 sm:py-24">
  <section class="text-center" aria-labelledby="page-title">
    <h1 id="page-title" class="mb-2 text-4xl font-bold tracking-tight sm:text-5xl">{siteData.name}</h1>
    <p class="mb-4 text-xl font-medium text-muted-foreground">{siteData.motto}</p>
    <p class="mx-auto max-w-xl leading-7 text-muted-foreground">{siteData.introduction}</p>
  </section>
</main>
